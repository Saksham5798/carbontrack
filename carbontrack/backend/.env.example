# ============================================
# CarbonTrack Backend Environment Variables
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Amazon RDS / Local MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=carbontrack_db
DB_USER=carbontrack_user
DB_PASSWORD=YourStrongPassword@123

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# AWS S3 Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=carbontrack-reports-bucket

# Application
FRONTEND_URL=http://localhost:8080
LOG_LEVEL=info
